@model Zajezdnia.Models.Zajezdnia_autobusow

<h2>Usuń zajezdnię?</h2>

<p>Czy na pewno chcesz usunąć zajezdnię <strong>@Model.Nazwa</strong>?</p>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Usuń</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Anuluj</a>
</form>